[Desktop Entry]
Version=1.0
Type=Application
Name=Firefox ESR Nursery Home Kiosk
Comment=Launch Firefox ESR in kiosk mode to local nursery home page
Exec=sh -c 'mkdir -p /tmp/firefox-kiosk-test-home && firefox-esr --no-remote --profile /tmp/firefox-kiosk-test-home -kiosk file:///media/kim/TV/dev/firefox/nurseryevalv2/home.html'
Icon=firefox-esr
Terminal=false
Categories=Network;WebBrowser;
StartupNotify=true
